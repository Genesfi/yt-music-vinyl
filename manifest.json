{
    "manifest_version": 3,
    "name": "YT Music Vinyl Disk",
    "version": "1.0",
    "description": "Transform your YouTube Music player into an aesthetic vinyl record with frosted glass effects and customizable spin speed.",
    "author": "Gusti N.",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://music.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ]
}